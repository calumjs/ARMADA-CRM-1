# SQLite database file used by Prisma (path is relative to the project root).
# Swap for a Postgres/libSQL URL later — the data layer is adapter-driven.
DATABASE_URL="file:./prisma/dev.db"

# ── Navigator (AI co-pilot) — optional ───────────────────────────────────────
# The Navigator degrades gracefully: with no key it shows a clear "no key"
# message and the app runs fully without live AI. Set a key to enable live AI.
#
# Vercel AI Gateway key. This is the variable to set for local live AI.
# Get one from the Vercel dashboard (AI Gateway) and paste it here.
AI_GATEWAY_API_KEY="your-ai-gateway-key-here"
#
# Alternatively, when deployed on Vercel the platform injects a VERCEL_OIDC_TOKEN
# automatically — either credential enables the Navigator, so you usually don't
# set this one by hand locally.
# VERCEL_OIDC_TOKEN=""
#
# Optional model override as a plain AI Gateway "provider/model" string.
# Defaults to "anthropic/claude-sonnet-4.5" when unset.
# NAVIGATOR_MODEL="anthropic/claude-sonnet-4.5"
